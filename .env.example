# .env.example – copy to .env or .env.local and customize
# Never commit real secrets!

# ─── App-wide Settings (prefix APP_) ────────────────────────
APP_AUTONOMOUS_MODE=3
APP_WHITELIST_ACTIONS=reset_interface,throttle_bandwidth
APP_ROLE=admin
APP_LOG_LEVEL=INFO
APP_PRUNE_DAYS=90
APP_DB_PATH=network_chan.db
APP_MODEL_PATH=mock_model.onnx
APP_AUDIT_MODE=off-peak

# ─── MQTT Settings (prefix MQTT_) ────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=networkchan
MQTT_PASSWORD=supersecret
MQTT_CLIENT_ID=network-chan-appliance-01
MQTT_TLS_CA_CERT=/etc/mosquitto/certs/ca.crt
MQTT_TLS_INSECURE=false
MQTT_KEEPALIVE=60